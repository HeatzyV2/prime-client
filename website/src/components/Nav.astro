---
const base = import.meta.env.BASE_URL
const links = [
  { href: '#features', label: 'Fonctionnalités' },
  { href: '#modules', label: 'Modules' },
  { href: '#launcher', label: 'Launcher' },
  { href: '#download', label: 'Télécharger' },
  { href: '#faq', label: 'FAQ' }
]
---

<header class="nav">
  <div class="container nav__inner">
    <a class="nav__brand" href={base}>
      <img src={`${base}logo.png`} alt="Prime Client" width="36" height="20" class="nav__logo" />
      <span>Prime Client</span>
    </a>
    <nav class="nav__links" aria-label="Navigation principale">
      {links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))}
    </nav>
    <a class="btn btn-primary nav__cta" href="#download">Télécharger</a>
  </div>
</header>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 16px 0;
    background: rgba(6, 6, 8, 0.72);
    border-bottom: 1px solid var(--prime-border);
    backdrop-filter: blur(20px);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .nav__brand {
    display: flex;
    align-items: center;
    gap: 10px;
    font-weight: 800;
    font-size: 1rem;
    letter-spacing: -0.02em;
  }

  .nav__logo {
    height: 22px;
    width: auto;
    filter: drop-shadow(0 0 12px rgba(255, 45, 66, 0.4));
  }

  .nav__links {
    display: flex;
    gap: 28px;
    margin-left: auto;
  }

  .nav__links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--prime-muted);
    transition: color 0.2s;
  }

  .nav__links a:hover {
    color: var(--prime-white);
  }

  .nav__cta {
    padding: 10px 20px;
    font-size: 0.875rem;
  }

  @media (max-width: 900px) {
    .nav__links {
      display: none;
    }

    .nav__cta {
      margin-left: auto;
    }
  }
</style>
