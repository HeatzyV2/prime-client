---
import { assetUrl } from '../utils/assetUrl'

interface Props {
  alt?: string
  class?: string
  width?: number
  height?: number
}

const { alt = 'Prime Client', class: className, width, height } = Astro.props
const src = assetUrl('logo.png')
---

<img src={src} alt={alt} class={className} width={width} height={height} loading="eager" decoding="async" />
