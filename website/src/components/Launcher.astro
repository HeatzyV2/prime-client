---
import PrimeLogo from './PrimeLogo.astro'

const perks = [
  'Connexion Microsoft & mode hors-ligne',
  'Gestionnaire d\'instances (mods, RAM, Java)',
  'Installation auto du mod Prime Client',
  'Intégration Modrinth (mods, packs, shaders)',
  'Analyseur de crash intelligent',
  'Mises à jour depuis GitHub Releases',
  'Discord Rich Presence launcher + jeu',
  'Store local, cosmétiques, amis & news'
]
---

<section class="section launcher" id="launcher">
  <div class="container launcher__inner">
    <div class="launcher__copy">
      <div class="section-label">Prime Launcher</div>
      <h2 class="section-title">Un launcher à la hauteur<br /><span class="text-gradient">du client</span></h2>
      <p class="section-lead">
        Pas besoin d'installer le mod à la main. Le launcher officiel télécharge Minecraft, Fabric,
        le mod Prime Client et te connecte en un clic — avec un design rouge & noir assorti.
      </p>
      <ul class="launcher__list">
        {perks.map((perk) => (
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" />
            </svg>
            {perk}
          </li>
        ))}
      </ul>
    </div>

    <div class="launcher__panel glass-card">
      <div class="launcher__panel-header">
        <PrimeLogo alt="" width={80} height={44} />
        <div>
          <strong>Prime Launcher</strong>
          <span>Windows · Electron</span>
        </div>
      </div>
      <div class="launcher__panel-rows">
        <div class="launcher__row">
          <span>Instances</span>
          <span class="launcher__pill">Fabric 1.21.11</span>
        </div>
        <div class="launcher__row">
          <span>Mod Prime Client</span>
          <span class="launcher__pill launcher__pill--ok">Auto-installé</span>
        </div>
        <div class="launcher__row">
          <span>Crash analyzer</span>
          <span class="launcher__pill launcher__pill--ok">Actif</span>
        </div>
        <div class="launcher__row">
          <span>Discord RPC</span>
          <span class="launcher__pill">Connecté</span>
        </div>
      </div>
      <div class="launcher__panel-footer">
        Prêt à jouer en un clic
      </div>
    </div>
  </div>
</section>

<style>
  .launcher__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  .launcher__list {
    list-style: none;
    margin-top: 32px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .launcher__list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--prime-muted);
  }

  .launcher__list svg {
    flex-shrink: 0;
    margin-top: 3px;
    color: var(--prime-success);
  }

  .launcher__panel {
    padding: 28px;
    box-shadow: var(--shadow-glow);
  }

  .launcher__panel-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--prime-border);
  }

  .launcher__panel-header img {
    filter: drop-shadow(0 0 16px rgba(255, 45, 66, 0.45));
  }

  .launcher__panel-header strong {
    display: block;
    font-size: 1.1rem;
  }

  .launcher__panel-header span {
    font-size: 0.8rem;
    color: var(--prime-muted-2);
  }

  .launcher__panel-rows {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .launcher__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.9rem;
    color: var(--prime-muted);
  }

  .launcher__pill {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--prime-border);
    color: var(--prime-white);
  }

  .launcher__pill--ok {
    background: rgba(34, 197, 94, 0.12);
    border-color: rgba(34, 197, 94, 0.3);
    color: var(--prime-success);
  }

  .launcher__panel-footer {
    margin-top: 24px;
    padding-top: 20px;
    border-top: 1px solid var(--prime-border);
    text-align: center;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--prime-red-bright);
  }

  @media (max-width: 900px) {
    .launcher__inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
</style>
