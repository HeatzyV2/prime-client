<section class="section download" id="download">
  <div class="container">
    <div class="download__card glass-card">
      <div class="download__glow" aria-hidden="true"></div>
      <div class="download__content">
        <div class="section-label">Téléchargement</div>
        <h2 class="section-title">Installe <span class="text-gradient">Prime Client</span></h2>
        <p class="section-lead">
          Télécharge le launcher Windows (.exe) depuis la dernière release GitHub.
          Le mod Prime Client s'installe automatiquement au premier lancement.
        </p>

        <div class="download__meta" id="release-meta">
          <span class="download__status" id="release-status">Recherche de la dernière version…</span>
        </div>

        <div class="download__actions">
          <a class="btn btn-primary download__btn" id="download-btn" href="#" aria-disabled="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
            <span id="download-label">Chargement…</span>
          </a>
          <a class="btn btn-ghost" href="https://github.com/HeatzyV2/prime-client/releases" target="_blank" rel="noopener noreferrer">
            Toutes les releases
          </a>
        </div>

        <div class="download__steps">
          <div class="download__step">
            <span class="download__step-num">1</span>
            <div>
              <strong>Télécharge</strong>
              <p>Prime-Launcher-Setup-x.x.x.exe</p>
            </div>
          </div>
          <div class="download__step">
            <span class="download__step-num">2</span>
            <div>
              <strong>Installe</strong>
              <p>Lance l'installateur NSIS</p>
            </div>
          </div>
          <div class="download__step">
            <span class="download__step-num">3</span>
            <div>
              <strong>Joue</strong>
              <p>Connecte-toi et appuie sur Play</p>
            </div>
          </div>
        </div>

        <p class="download__note">
          Windows 10/11 · Java 21 inclus automatiquement · Minecraft 1.21.11 (Fabric)
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .download__card {
    position: relative;
    padding: 56px;
    overflow: hidden;
    text-align: center;
  }

  .download__glow {
    position: absolute;
    top: -50%;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 400px;
    background: radial-gradient(ellipse, rgba(255, 45, 66, 0.2), transparent 70%);
    pointer-events: none;
  }

  .download__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .download__content .section-lead {
    margin-bottom: 24px;
  }

  .download__meta {
    margin-bottom: 28px;
  }

  .download__status {
    display: inline-block;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--prime-border);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--prime-muted);
  }

  .download__status--ready {
    border-color: rgba(34, 197, 94, 0.35);
    color: var(--prime-success);
  }

  .download__status--error {
    border-color: rgba(239, 68, 68, 0.35);
    color: var(--prime-error);
  }

  .download__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-bottom: 48px;
  }

  .download__btn {
    min-width: 280px;
    font-size: 1.05rem;
    padding: 16px 32px;
  }

  .download__btn[aria-disabled='true'] {
    opacity: 0.6;
    pointer-events: none;
  }

  .download__steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    width: 100%;
    max-width: 720px;
    margin-bottom: 28px;
    text-align: left;
  }

  .download__step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
  }

  .download__step-num {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--prime-red-subtle);
    border: 1px solid rgba(255, 45, 66, 0.3);
    color: var(--prime-red-bright);
    font-weight: 800;
    font-size: 0.85rem;
  }

  .download__step strong {
    display: block;
    font-size: 0.9rem;
    margin-bottom: 4px;
  }

  .download__step p {
    font-size: 0.8rem;
    color: var(--prime-muted);
  }

  .download__note {
    font-size: 0.8rem;
    color: var(--prime-muted-2);
  }

  @media (max-width: 700px) {
    .download__card {
      padding: 32px 24px;
    }

    .download__steps {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const REPO = 'HeatzyV2/prime-client'
  const RELEASES_URL = `https://github.com/${REPO}/releases`
  const statusEl = document.getElementById('release-status')
  const btnEl = document.getElementById('download-btn')
  const labelEl = document.getElementById('download-label')

  function pickWindowsAsset(assets) {
    if (!assets?.length) return null
    return (
      assets.find((a) => /setup.*\.exe$/i.test(a.name)) ??
      assets.find((a) => /\.exe$/i.test(a.name)) ??
      null
    )
  }

  async function loadRelease() {
    try {
      const res = await fetch(`https://api.github.com/repos/${REPO}/releases/latest`, {
        headers: { Accept: 'application/vnd.github+json' }
      })

      if (!res.ok) {
        throw new Error(res.status === 404 ? 'Aucune release publiée' : `HTTP ${res.status}`)
      }

      const release = await res.json()
      const asset = pickWindowsAsset(release.assets)
      const version = release.tag_name?.replace(/^v/i, '') ?? '?'

      if (statusEl) {
        statusEl.textContent = asset
          ? `Dernière version : v${version} · ${asset.name}`
          : `Version v${version} — .exe non trouvé sur la release`
        statusEl.classList.add(asset ? 'download__status--ready' : 'download__status--error')
      }

      if (asset && btnEl && labelEl) {
        btnEl.href = asset.browser_download_url
        btnEl.setAttribute('aria-disabled', 'false')
        btnEl.setAttribute('download', asset.name)
        labelEl.textContent = `Télécharger v${version}`
      } else if (btnEl && labelEl) {
        btnEl.href = RELEASES_URL
        btnEl.setAttribute('aria-disabled', 'false')
        labelEl.textContent = 'Voir les releases'
      }
    } catch (err) {
      if (statusEl) {
        statusEl.textContent =
          err instanceof Error && err.message === 'Aucune release publiée'
            ? 'Pas encore de release — build & push un tag v* sur GitHub'
            : 'Impossible de joindre GitHub — réessaie plus tard'
        statusEl.classList.add('download__status--error')
      }
      if (btnEl && labelEl) {
        btnEl.href = RELEASES_URL
        btnEl.setAttribute('aria-disabled', 'false')
        labelEl.textContent = 'Releases GitHub'
      }
    }
  }

  loadRelease()
</script>
